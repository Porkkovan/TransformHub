# =============================================================================
# TransformHub - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# Lines marked [REQUIRED] must be set before running the application.
# Lines marked [OPTIONAL] have sensible defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------

# [OPTIONAL] Database name
POSTGRES_DB=transformhub

# [OPTIONAL] Database user
POSTGRES_USER=transformhub

# [REQUIRED] Database password - change this!
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_in_production

# [OPTIONAL] Full connection string (constructed from the above by default).
# Override only if connecting to an external database.
DATABASE_URL=postgresql://transformhub:change_me_in_production@postgres:5432/transformhub

# -----------------------------------------------------------------------------
# Database Connection Pool (agent-service)
# -----------------------------------------------------------------------------

# [OPTIONAL] Minimum number of connections kept open in the pool
DB_POOL_MIN=5

# [OPTIONAL] Maximum number of connections the pool can open
DB_POOL_MAX=30

# [OPTIONAL] Seconds to wait when acquiring a connection from the pool
DB_CONN_TIMEOUT=30

# [OPTIONAL] Seconds to wait for a single SQL command to complete
DB_CMD_TIMEOUT=60

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# [OPTIONAL] Redis connection URL (used for job queue, caching, event bus)
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Anthropic (AI Agent Backend)
# -----------------------------------------------------------------------------

# [REQUIRED] Anthropic API key for Claude-based agents
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------------------
# Next.js / NextAuth
# -----------------------------------------------------------------------------

# [REQUIRED for production] Secret for session encryption
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32

# [OPTIONAL] Canonical URL for NextAuth callbacks
# Set to your production domain in deployment (e.g., https://app.yourdomain.com)
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------

# [OPTIONAL] API key for protecting Next.js API routes
# Leave empty to disable API key authentication
API_KEY=

# [OPTIONAL] Comma-separated allowed origins for CORS
# In production, set this to your actual domain(s)
ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# OpenAI (Vector Embeddings)
# -----------------------------------------------------------------------------

# [OPTIONAL] OpenAI API key for generating vector embeddings (text-embedding-3-small)
# If not set, document search falls back to keyword matching
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Agent Service
# -----------------------------------------------------------------------------

# [OPTIONAL] URL of the Python agent execution service
AGENT_SERVICE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# [OPTIONAL] Log level for the agent-service (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
